# ------------------------------------------------------------------------------
# Servicimmo v2 — Variables d'environnement (app Pilote + site vitrine)
# Copier ce fichier vers `.env.local` et remplir les valeurs.
# Ne JAMAIS committer `.env.local` (cf. .gitignore).
# ------------------------------------------------------------------------------

# --- Supabase ---------------------------------------------------------------
# URL publique du projet Supabase (format : https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clé anon (publique, côté client — limitée par les policies RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service_role (SECRÈTE — côté serveur uniquement, bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (paiements) -----------------------------------------------------
# Clés depuis le dashboard Stripe (utiliser les clés test pour le dev).
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Email transactionnel (Resend) ------------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=

# Adresse d'expédition des emails (domaine validé dans Resend avec DKIM)
EMAIL_FROM=devis@servicimmo.fr

# Adresse interne qui reçoit les notifications "nouvelle demande"
EMAIL_INTERNAL=contact@servicimmo.fr

# Alias legacy (même valeur que EMAIL_INTERNAL) — gardé pour backward compat
# le temps de bascule du code existant.
EMAIL_INTERNAL_NOTIFICATION=contact@servicimmo.fr

# --- Pappers (enrichissement SIRET) -----------------------------------------
# https://www.pappers.fr/api
PAPPERS_API_KEY=

# --- Analytics (RGPD-friendly) ----------------------------------------------
# Domaine configuré dans Plausible (ex: servicimmo.fr)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=servicimmo.fr

# --- Portail client/prescripteur --------------------------------------------
# Secret HS256 utilisé pour signer les magic links du portail (Sprint 4+).
# Générer via: openssl rand -base64 48
JWT_PORTAL_SECRET=

# --- Config client (pour le SaaS futur multi-cabinet) -----------------------
# Identifie quel dossier lib/clients/ utiliser. Aujourd'hui: "servicimmo".
NEXT_PUBLIC_CLIENT=servicimmo

# --- App --------------------------------------------------------------------
# URL publique utilisée pour metadataBase, liens emails, redirections OAuth
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Démo / présentations client --------------------------------------------
# Si les deux variables sont renseignées, un bouton "Connexion démo" apparaît
# sur /login et auto-soumet ces credentials. À NE PAS configurer en production
# publique (sauf si le compte démo a un accès limité et des données factices).
NEXT_PUBLIC_DEMO_EMAIL=
NEXT_PUBLIC_DEMO_PASSWORD=
